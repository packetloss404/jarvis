# Copy to .env for local Expo (optional). Only EXPO_PUBLIC_* are embedded in the client.
# Relay WebSocket endpoint shared by the [code] terminal and [chat] Room transport.
# Defaults to the production relay (wss://jarvis-relay-production-3eb6.up.railway.app/ws) if unset.
# EXPO_PUBLIC_DEFAULT_RELAY_URL=wss://jarvis-relay-production-3eb6.up.railway.app/ws
# EXPO_PUBLIC_RELAY_DEBUG=1
